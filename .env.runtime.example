NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=replace-with-strong-nacos-password
NACOS_GROUP=DEFAULT_GROUP
NACOS_NAMESPACE=

# Optional: set MYSQL_URL only when you need to override host/port/database.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=smart_exam_app
MYSQL_PASSWORD=replace-with-strong-mysql-app-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=smart_exam_app
RABBITMQ_PASSWORD=replace-with-strong-rabbit-password

JWT_SECRET=replace-with-32-byte-or-longer-secret
BOOTSTRAP_DEMO_USERS=false
