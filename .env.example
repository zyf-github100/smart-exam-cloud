# Docker / middleware runtime
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_PORT=3306
MIDDLEWARE_BIND_HOST=127.0.0.1

REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_PORT=6379

RABBITMQ_DEFAULT_USER=smart_exam_app
RABBITMQ_DEFAULT_PASS=replace-with-strong-rabbit-password
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

NACOS_HTTP_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_RAFT_PORT=9849
NACOS_AUTH_ENABLE=true
NACOS_AUTH_TOKEN=replace-with-base64-encoded-32-byte-or-longer-secret
NACOS_AUTH_IDENTITY_KEY=replace-with-random-identity-key
NACOS_AUTH_IDENTITY_VALUE=replace-with-random-identity-value
NACOS_AUTH_TOKEN_EXPIRE_SECONDS=18000
